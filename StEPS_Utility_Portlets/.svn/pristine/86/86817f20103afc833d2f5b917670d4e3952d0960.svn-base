package com.webmethods.caf.testportletone;

public class AsyncError extends com.webmethods.caf.faces.bean.BaseFacesSessionBean {

	private java.lang.String error_boolean;
	private java.lang.String error_text;

	/**
     * Override this method to release any resources associated with this session.
     * Please note, the FacesContext is not valid for this function 
     */
    protected void release() {
    	this.setError_boolean("false");
    	this.setError_boolean("");
    }

	public java.lang.String getError_boolean()  {
		
		return error_boolean;
	}

	public void setError_boolean(java.lang.String error_boolean)  {
		this.error_boolean = error_boolean;
	}

	public java.lang.String getError_text()  {
		
		return error_text;
	}

	public void setError_text(java.lang.String error_text)  {
		this.error_text = error_text;
	};
}