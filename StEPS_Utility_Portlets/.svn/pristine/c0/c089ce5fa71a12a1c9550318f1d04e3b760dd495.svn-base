<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE faces-config PUBLIC
    "-//Sun Microsystems, Inc.//DTD JavaServer Faces Config 1.1//EN"
    "http://java.sun.com/dtd/web-facesconfig_1_1.dtd">

<faces-config>
	<application>
		<message-bundle>com.webmethods.caf.AppResources</message-bundle>
		<locale-config>
			<default-locale>en_US</default-locale>
		</locale-config>
	</application>

	<managed-bean>
		<description>applicationbean</description>
		<display-name>STEPS_UI_User</display-name>
		<managed-bean-name>Steps_ui_user</managed-bean-name>
		<managed-bean-class>com.webmethods.caf.Steps_ui_user</managed-bean-class>
		<managed-bean-scope>application</managed-bean-scope>
	</managed-bean>
	<managed-bean>
		<description>portletbean</description>
		<display-name>RoleMembership</display-name>
		<managed-bean-name>RoleMembership</managed-bean-name>
		<managed-bean-class>com.webmethods.caf.rolemembership.RoleMembership</managed-bean-class>
		<managed-bean-scope>session</managed-bean-scope>
		<managed-property>
			<description>Specifies whether the session bean expires when the pageflow is out of scope</description>
			<display-name>Expire With Page Flow</display-name>
			<property-name>expireWithPageFlow</property-name>
			<property-class>java.lang.Boolean</property-class>
			<value>true</value>
		</managed-property>
	</managed-bean>
	<managed-bean>
		<description>pagebean</description>
		<display-name>RoleMembership/default</display-name>
		<managed-bean-name>RoleMembershipDefaultviewView</managed-bean-name>
		<managed-bean-class>com.webmethods.caf.rolemembership.RoleMembershipDefaultviewView</managed-bean-class>
		<managed-bean-scope>session</managed-bean-scope>
		<managed-property>
			<description>Specifies whether the session bean expires when the pageflow is out of scope</description>
			<display-name>Expire With Page Flow</display-name>
			<property-name>expireWithPageFlow</property-name>
			<property-class>java.lang.Boolean</property-class>
			<value>true</value>
		</managed-property>
	</managed-bean>
	<navigation-rule>
		<from-view-id>RoleMembership/*</from-view-id>
		<navigation-case>
			<from-outcome>default</from-outcome>
			<to-view-id>/RoleMembership/default.view</to-view-id>
		</navigation-case>
	</navigation-rule>
