package com.webmethods.caf.testportletone;

public class ErrorQuantities extends com.webmethods.caf.faces.bean.BaseFacesSessionBean {

	private java.lang.String async;
	private java.lang.String sync;
	/**
     * Override this method to release any resources associated with this session.
     * Please note, the FacesContext is not valid for this function 
     */
    protected void release() {
    	this.setAsync("1");
    	this.setSync("1");
    }

	public java.lang.String getAsync()  {
		
		return async;
	}

	public void setAsync(java.lang.String async)  {
		this.async = async;
	}

	public java.lang.String getSync()  {
		
		return sync;
	}

	public void setSync(java.lang.String sync)  {
		this.sync = sync;
	};
}