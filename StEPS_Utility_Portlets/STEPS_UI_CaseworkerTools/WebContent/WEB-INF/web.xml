			<web-resource-name>Pages</web-resource-name>
			<url-pattern>*.view</url-pattern>
			<url-pattern>*.jsp</url-pattern>
			<url-pattern>*.html</url-pattern>
			<url-pattern>*.htm</url-pattern>
		</web-resource-collection>
