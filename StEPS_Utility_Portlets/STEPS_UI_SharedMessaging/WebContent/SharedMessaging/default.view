              <property name='onblur' value=' ' />
              <property name='onclick' value='//Reset the sharedMessaging functionality&#13;&#10;saas_StEPS_toplevelarray = [];&#13;&#10;saas_StEPS_message_no = 0;&#13;&#10;var saas_StEPS_dbType = CAF.model(&apos;#{activePageBean.clientIds[&quot;messageType&quot;]}&apos;);&#13;&#10;var saas_StEPS_dbTitle = CAF.model(&apos;#{activePageBean.clientIds[&quot;messageTitle&quot;]}&apos;);&#13;&#10;var saas_StEPS_dbText = CAF.model(&apos;#{activePageBean.clientIds[&quot;messageText&quot;]}&apos;);&#13;&#10;var saas_StEPS_dbMsgNo = CAF.model(&apos;#{activePageBean.clientIds[&quot;messageNumber&quot;]}&apos;);&#13;&#10;var saas_StEPS_dbMsgTtl = CAF.model(&apos;#{activePageBean.clientIds[&quot;messageTotal&quot;]}&apos;);&#13;&#10;saas_StEPS_dbType.setValue(&quot;&quot;);&#13;&#10;saas_StEPS_dbTitle.setValue(&quot;&quot;);&#13;&#10;saas_StEPS_dbText.setValue(&quot;&quot;);&#13;&#10;saas_StEPS_dbMsgNo.setValue(&quot;&quot;);&#13;&#10;saas_StEPS_dbMsgTtl.setValue(&quot;&quot;);&#13;&#10;&#13;&#10;//Delete the current error elements from the document ready to handle subsequent&#13;&#10;//AJAX requests.&#13;&#10;var saas_StEPS_aa_delete = document.getElementsByTagName(&quot;error&quot;);&#13;&#10;var saas_StEPS_bb_delete = document.getElementsByTagName(&quot;custom:error&quot;);&#13;&#10;while(saas_StEPS_aa_delete.length &gt; 0)&#13;&#10;{&#13;&#10;saas_StEPS_aa_delete[0].parentNode.removeChild(saas_StEPS_aa_delete[0]);&#13;&#10;}&#13;&#10;while(saas_StEPS_bb_delete.length &gt; 0)&#13;&#10;{&#13;&#10;saas_StEPS_bb_delete[0].parentNode.removeChild(saas_StEPS_bb_delete[0]);&#13;&#10;}&#13;&#10;CAF.model(&apos;#{activePageBean.clientIds[&quot;sharedMessagingModalDialog&quot;]}&apos;).hide();&#13;&#10;' />
              <property name='ondblclick' value=' ' />
