	<managed-bean>
		<managed-bean-name>SyncError</managed-bean-name>
		<managed-bean-class>com.webmethods.caf.testportletone.SyncError</managed-bean-class>
		<managed-bean-scope>session</managed-bean-scope>
		<managed-property>
			<description>Specifies whether the session bean expires when the pageflow is out of scope</description>
			<display-name>Expire With Page Flow</display-name>
			<property-name>expireWithPageFlow</property-name>
			<property-class>java.lang.Boolean</property-class>
			<value>true</value>
		</managed-property>
	</managed-bean>
	<managed-bean>
		<managed-bean-name>ErrorQuantities</managed-bean-name>
		<managed-bean-class>com.webmethods.caf.testportletone.ErrorQuantities</managed-bean-class>
		<managed-bean-scope>session</managed-bean-scope>
		<managed-property>
