	<navigation-rule>
		<from-view-id>TestPortletOne/*</from-view-id>
		<navigation-case>
			<from-outcome>default</from-outcome>
			<to-view-id>/TestPortletOne/default.view</to-view-id>
		</navigation-case>
	</navigation-rule>
	<managed-bean>
		<managed-bean-name>ClientSideError</managed-bean-name>
		<managed-bean-class>com.webmethods.caf.testportletone.ClientSideError</managed-bean-class>
		<managed-bean-scope>session</managed-bean-scope>
		<managed-property>
